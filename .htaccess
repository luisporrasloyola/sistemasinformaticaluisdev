Options -Indexes
DirectoryIndex index.php
AddDefaultCharset UTF-8

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "\.(sql|log|env|ini|bak|backup|old)$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(self), geolocation=(self)"
    Header always set Feature-Policy "camera 'self'; geolocation 'self'"
</IfModule>